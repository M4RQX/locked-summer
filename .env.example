# 🔒☀️ LOCKED SUMMER — example env file
# Copy to `.env.local` (NEVER commit it).
#
# Neon Postgres connection string (https://console.neon.tech).
# Use the "pooled" URL from "Connection Details" → "Direct connection" or "Pooled".
# Example shape (do not paste a real one in commits):
VITE_DATABASE_URL=postgres://USER:PASSWORD@ep-xxxxx-pooler.eu-central-1.aws.neon.tech/locked_summer?sslmode=require

# Base URL — match the GitHub Pages path. Default: /locked-summer/
# Override only if hosting elsewhere (Vercel, Netlify, custom domain).
# VITE_BASE_PATH=/locked-summer/
